############################################
# Research Agent 环境变量示例配置 (.env.example)
# 复制本文件为 `.env`，并填入你自己的密钥
############################################

# 硅基流动 SiliconFlow API Key（用于调用大模型）
# 在硅基流动控制台获取，例如：sk-xxxx...
SILICONFLOW_API_KEY=

# （可选）OpenAI 兼容配置覆盖项
# 如果你想切换到其它 OpenAI-compatible 服务商，可直接设置下面两个变量
# OPENAI_BASE_URL=https://api.siliconflow.cn/v1
# OPENAI_API_KEY=sk-xxxx

# 阿里 IQS 搜索 API Key（已在代码中默认绕过，不再使用）
# 保留字段仅为兼容旧配置；留空即可
IQS_API_KEY=

# Google Serper 搜索 API Keys（英文/国际搜索）
# 支持多个，用英文逗号分隔，例如：key1,key2,key3
SERPER_API_KEYS=

# Jina Reader API Keys（可选，用于网页清洗）
# 同样支持多个，用英文逗号分隔
JINA_API_KEYS=

# 主推理模型名称（硅基流动控制台中的模型 ID）
# 示例格式：Qwen/Qwen2.5-7B-Instruct（以你账号可用列表为准）
AGENT_MODEL=

